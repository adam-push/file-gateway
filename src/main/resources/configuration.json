{
  "id"                  : "file-gateway",
  "diffusion" : {
    "url"       : "ws://localhost:8090",
    "principal" : "admin",
    "password"  : "password"
  },
  "services" : [
    {
      "serviceName" : "File polling service",
      "serviceType" : "POLLING_JSON_SOURCE",
      "config" : {
        "framework" : {
          "pollIntervalMs" : 1000,
          "pollTimeoutMs"  : 500,
          "payloadConverters" : [{"name": "$CSV_to_JSON"}]
        },
        "application" : {
          "directory" : "csv-data",
          "stopAfterInitialLoad" : false
        }
      }
    }
  ]
}
